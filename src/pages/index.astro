---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
    html, body {
  height: 100%;
  overflow: hidden;
}

main {
  height: calc(100vh - 60px); /* minus header height */
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}

footer {
  display: none;
}
  .home-hero { text-align: left; padding: 3rem 2.5rem; }
  .home-hero h1 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 0.3rem; }
  .home-hero h2 { font-size: 1rem; font-weight: 400; color: rgba(255,255,255,0.4); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1.8rem; }
  .hero-tag { font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: #4da6ff; margin-bottom: 1.2rem; }
  .hero-intro { font-size: 1.05rem; color: rgba(255,255,255,0.85); line-height: 1.8; margin-bottom: 1rem; }
  .hero-sub { font-size: 0.95rem; color: rgba(255,255,255,0.5); line-height: 1.85; margin-bottom: 2rem; }
  .hero-sub em { color: rgba(255,255,255,0.7); font-style: normal; font-weight: 500; }
  .hero-footer { font-size: 0.9rem; color: rgba(255,255,255,0.4); letter-spacing: 0.03em; margin-bottom: 1.5rem; }
</style>
	</head>
	<body>
	<video class="earth-video" autoplay loop muted playsinline>
<source src="/videos/earth_bg_compressed.webm" type="video/mp4" />  </video>
		<Header />
		<main>
		<div class="glass-panel home-hero">
  <div class="hero-tag">M.Tech CSE · ECE Background · Building in Public</div>

  <h1>Hey, I'm <span class="highlight">Kamalesh</span></h1>

  <h2>Welcome to Early Commit</h2>

  <p class="hero-intro">
    M.Tech CSE student with an ECE background — diving deep into software
    development and sharing <span class="highlight">everything I learn</span> along the way.
  </p>

  <p class="hero-sub">
    I read technical blogs, papers, and dev write-ups from around the world.
    This is where I share my honest take — filtered through the lens of someone
    <em>early in their career</em>, figuring things out in public.
  </p>

  <div class="topic-grid">
    <div class="topic-card">🧠 <span>DSA & Problem Solving</span></div>
    <div class="topic-card">⚙️ <span>System Design</span></div>
    <div class="topic-card">🌐 <span>Tech Opinions</span></div>
    <div class="topic-card">🛠️ <span>Dev Tools & Builds</span></div>
  </div>

  <p class="hero-footer">
    Starting early. Building in public. <span class="highlight">One commit at a time.</span>
  </p>

  <a href="/blog" class="cta-button">Read the Blog →</a>
</div>
		</main>
		<Footer />
	</body>
</html>
